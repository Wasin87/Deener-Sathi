# --- Vercel Deployment Environment Variables ---

# GEMINI_API_KEY: Required for the AI Assistant (Deener Sathi Assistant).
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Optional / Internal ---
# APP_URL: The URL where the app is hosted. Vercel provides this automatically as VERCEL_URL if needed,
# but for most features in this app, it's not strictly required unless you add OAuth.
APP_URL=https://your-project-name.vercel.app
